{
  "name": "linkding-ext",
  "version": "1.0.1",
  "description": "Browser extension for Linkding bookmarks",
  "license": "MIT",
  "author": "Mirko K.",
  "scripts": {
    "dev:chrome": "webpack --config webpack.config.ts --env target=chrome --watch",
    "dev:chrome-newtab": "webpack --config webpack.config.ts --env target=chrome-newtab --watch",
    "dev:firefox": "webpack --config webpack.config.ts --env target=firefox --watch",
    "build:chrome": "webpack --config webpack.config.ts --env target=chrome --env mode=production",
    "build:chrome-newtab": "webpack --config webpack.config.ts --env target=chrome-newtab --env mode=production",
    "build:firefox": "webpack --config webpack.config.ts --env target=firefox --env mode=production",
    "build": "pnpm run build:firefox && pnpm run build:chrome && pnpm run build:chrome-newtab",
    "package": "pnpm run build && node scripts/package.mjs",
    "screenshots": "node scripts/screenshots.mjs",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.0",
    "webpack-merge": "^6.0.0"
  }
}
