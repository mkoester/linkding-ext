{
  "name": "linkding-ext",
  "version": "0.1.19",
  "description": "Browser extension for Linkding bookmarks",
  "scripts": {
    "dev:chrome": "webpack --config webpack.config.ts --env browser=chrome --watch",
    "dev:firefox": "webpack --config webpack.config.ts --env browser=firefox --watch",
    "build:chrome": "webpack --config webpack.config.ts --env browser=chrome",
    "build:firefox": "webpack --config webpack.config.ts --env browser=firefox",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.0",
    "webpack-merge": "^6.0.0"
  }
}
