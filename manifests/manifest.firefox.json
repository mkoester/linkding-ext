{
  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "Bookmarks+",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
