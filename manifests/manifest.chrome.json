{
  "minimum_chrome_version": "114",
  "permissions": ["favicon", "sidePanel", "unlimitedStorage"],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "commands": {
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open the Bookmarks+ side panel"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
